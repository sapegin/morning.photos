{
  "name": "morning-photos",
  "description": "Artem Sapegin Photography",
  "author": "Artem Sapegin <artem@sapegin.me> (https://sapegin.me/)",
  "license": "SEE LICENSE IN <Readme.md>",
  "private": true,
  "scripts": {
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "npm run lint:js",
    "lint:js": "eslint . --cache --fix",
    "format": "prettier --log-level warn --write \"**/*.{js,ts,tsx,astro,md}\"",
    "pretest": "npm run lint",
    "test": "astro check",
    "sync": "tsx scripts/sync.ts",
    "posttest": "npm run format",
    "prepare": "husky; panda codegen"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "browserslist": [
    ">1%",
    "last 1 version",
    "Firefox ESR",
    "not dead"
  ],
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.3.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.4.0",
    "@pandacss/dev": "^0.53.6",
    "@types/lodash": "^4.17.17",
    "@types/react": "^19.1.5",
    "astro": "^5.8.0",
    "clsx": "^2.1.1",
    "csstype": "^3.1.3",
    "github-slugger": "^2.0.0",
    "hast-util-to-string": "3.0.1",
    "image-size": "^2.0.2",
    "lodash": "^4.17.21",
    "markdown-it": "^14.1.0",
    "markdown-to-jsx": "^7.7.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-group": "^4.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "richtypo": "^7.0.1",
    "sanitize-html": "^2.17.0",
    "sharp": "0.34.5",
    "tamia": "^7.1.11",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/markdown": "^6.4.0",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.0",
    "eslint": "^9.27.0",
    "eslint-config-tamia": "^9.2.3",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "exifreader": "^4.31.0",
    "husky": "^9.1.7",
    "nano-staged": "0.9.0",
    "prettier": "3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "nano-staged": {
    "*.{js,cjs,mjs,ts,tsx,astro,json,md}": "prettier --write",
    "*.{js,cjs,mjs,ts,tsx,astro}": "eslint --cache --fix"
  }
}
